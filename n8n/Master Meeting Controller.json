    {
      "parameters": {
        "jsCode": "// This version handles the \"Always Output Data\" empty case correctly\nconst rawInput = $input.all();\nconst events = rawInput.filter(e => e.json.start);\nconst body = $('Webhook').item.json.body || {};\nconst profile = $('Get User Profile').item.json || { signature: \"\" };\nconst senderName = body.mail?.sender_name || 'there';\n\n// Professional Slot Hunting Logic\nconst START_HOUR = 9; const END_HOUR = 18; const istOffset = 5.5;\n\nfunction isBusy(start, end) {\n  return events.some(e => {\n    const eStart = new Date(e.json.start.dateTime || e.json.start.date);\n    const eEnd = new Date(e.json.end.dateTime || e.json.end.date);\n    return (start < eEnd && end > eStart);\n  });\n}\n\nconst availableSlots = []; const now = body.start_time ? new Date(body.start_time) : new Date(); \nfor (let d = 0; d < 3; d++) {\n  const day = new Date(now); day.setDate(now.getDate() + d);\n  day.setUTCHours(Math.floor(START_HOUR - istOffset), 30, 0, 0);\n  for (let h = 0; h < (END_HOUR - START_HOUR) * 2; h++) {\n    const slotStart = new Date(day); slotStart.setMinutes(day.getMinutes() + (h * 30));\n    const slotEnd = new Date(slotStart); slotEnd.setMinutes(slotStart.getMinutes() + 30);\n    if (slotStart > now && !isBusy(slotStart, slotEnd)) {\n      availableSlots.push(slotStart); if (availableSlots.length >= 5) break;\n    }\n  }\n  if (availableSlots.length >= 5) break;\n}\n\nconst slotStrings = availableSlots.map(s => s.toLocaleString('en-IN', { \n  weekday: 'long', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata' \n}));\n\n// RALPH LOOP: Export raw ISOs for frontend buttons\nconst slots_raw = availableSlots.map(s => s.toISOString());\n\nconst suggestedDraft = `Hi ${senderName},\\n\\nI've reviewed my calendar and I have the following availability (IST):\\n\\n[DYNAMIC_SLOTS_HERE]\\n\\nDo any of these times work for a call?\\n\\n${profile.signature}`;\n\n// ... [existing data processing code above remains the same] ...\n\nconst finalRecipient = body.recipient || \n                       $node[\"Fetch Google Event ID\"].json.recipient || \n                       body.mail?.sender_mail;\nreturn {\n  draft: {\n    email_action_id: body.email_action_id,\n    content: suggestedDraft,\n    recipient: finalRecipient,\n    subject: body.subject || (body.mail?.subject ? `Re: ${body.mail.subject}` : \"Meeting Reschedule\"),\n    type: \"Scheduling Proposal\",\n    reasoning: body.action === \"reschedule\" ? \"Auto-probe for requested reschedule.\" : \"Autonomous slot hunting completed.\",\n    tags: [\"Scheduling\", body.action === \"reschedule\" ? \"Reschedule-Auth\" : \"Auto-Probe\"],\n    suggested_slots: slots_raw\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2576,
        2496
      ],
      "id": "90ef936b-f68f-4515-b1d7-20995fe4dd71",
      "name": "3-Day Probe"
    },
    {
      "parameters": {
        "jsCode": "const events = $input.all();\nconst body = $('Webhook').item.json.body || {};\nconst targetStart = new Date(body.start_time);\nconst targetEnd = new Date(targetStart.getTime() + 30 * 60000);\n\n// Filter out empty items produced by \"Always Output Data\"\nconst realEvents = events.filter(e => e.json.start);\n\nconst isBusy = realEvents.some(e => {\n  const eStart = new Date(e.json.start.dateTime || e.json.start.date);\n  const eEnd = new Date(e.json.end.dateTime || e.json.end.date);\n  return (targetStart < eEnd && targetEnd > eStart);\n});\n\nif (isBusy) {\n  throw new Error(\"CONFLICT: The requested slot is no longer available. Manual rescheduling required.\");\n}\nreturn { status: \"Clear\" };"
      },
